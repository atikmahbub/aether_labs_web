# Resend — powers the contact form (/api/contact)
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=

# Where enquiries are delivered (defaults to hello@doodledash.uk)
CONTACT_TO=hello@doodledash.uk

# Verified sender. Until doodledash.uk is verified in Resend, leave the default
# below (onboarding@resend.dev delivers to the Resend account owner only).
# After verifying the domain, set: "Doodle Dash Labs <hello@doodledash.uk>"
CONTACT_FROM=Doodle Dash Labs <onboarding@resend.dev>
